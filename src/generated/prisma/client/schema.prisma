generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma/client"
  moduleFormat = "commonjs" // ← add this line
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  isVerified       Boolean   @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  jobApplications    JobApplication[]
  interviewQuestions InterviewQuestion[]

  @@map("users")
}

model JobApplication {
  id             String  @id @default(uuid())
  userId         String
  companyName    String
  jobTitle       String
  status         String // applied, interviewing, offer, rejected
  jobUrl         String?
  jobDescription String
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id])
  resume              Resume?
  aiSuggestions       AISuggestion[]
  acceptedSuggestions AcceptedSuggestion[]
  interviewPreps      InterviewPrep[]

  @@map("job_applications")
}

model Resume {
  id               String @id @default(uuid())
  jobApplicationId String @unique
  fileUrl          String
  parsedText       String
  version          Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id])

  @@map("resumes")
}

model AISuggestion {
  id               String @id @default(uuid())
  jobApplicationId String

  originalText  String
  suggestedText String

  type        String // grammar, rewrite, keyword
  status      String @default("pending") // pending | accepted | rejected
  explanation String // why the suggestion was made (optional)

  createdAt DateTime @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id])

  @@index([jobApplicationId])
  @@map("ai_suggestions")
}

model AcceptedSuggestion {
  id               String @id @default(uuid())
  jobApplicationId String

  originalText  String
  suggestedText String

  createdAt DateTime @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id])

  @@map("accepted_suggestions")
}

model InterviewPrep {
  id               String   @id @default(uuid())
  jobApplicationId String
  createdAt        DateTime @default(now())

  jobApplication JobApplication      @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade) // ← InterviewPrep deleted when JobApplication deleted
  questions      InterviewQuestion[]

  @@map("interview_preps")
}

model InterviewQuestion {
  id              String   @id @default(uuid())
  interviewPrepId String? // ← nullable, not required
  userId          String // ← always present
  question        String
  answer          String
  topic           String
  keyPoints       String[]
  createdAt       DateTime @default(now())

  interviewPrep InterviewPrep? @relation(fields: [interviewPrepId], references: [id], onDelete: SetNull)
  user          User           @relation(fields: [userId], references: [id])

  @@map("interview_questions")
}
